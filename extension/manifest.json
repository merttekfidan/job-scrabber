{
  "manifest_version": 3,
  "name": "Job Scrabber — AI Career Co-Pilot",
  "version": "2.0.0",
  "description": "Your AI-powered career companion. Instantly capture job listings from 15+ job boards, get AI analysis, interview prep, and track your entire application pipeline.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://aware-endurance-production-13b8.up.railway.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.glassdoor.co.uk/*",
        "*://*.monster.com/*",
        "*://*.kariyer.net/*",
        "*://*.seek.com/*",
        "*://*.seek.com.au/*",
        "*://*.ziprecruiter.com/*",
        "*://*.dice.com/*",
        "*://*.wellfound.com/*",
        "*://*.lever.co/*",
        "*://*.greenhouse.io/*",
        "*://*.workday.com/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.smartrecruiters.com/*",
        "*://*.nofluffjobs.com/*",
        "*://*.pracuj.pl/*",
        "*://*.justjoin.it/*",
        "*://*.remoteok.com/*",
        "*://*.weworkremotely.com/*",
        "*://*.angel.co/*",
        "*://*.hired.com/*",
        "*://*.reed.co.uk/*",
        "*://*.totaljobs.com/*",
        "*://*.stepstone.de/*",
        "*://*.xing.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}